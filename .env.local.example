# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI (Phase 2  Tone Filter + Phase 3  Learn tab)
OPENAI_API_KEY=sk-...

# App URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# CRON_SECRET = 434242424
# Cron security
# Use this same secret in cronjob.org Authorization header:
# Authorization: Bearer <CRON_SECRET>
CRON_SECRET=replace-with-a-long-random-secret

# Single cron orchestrator endpoint to call from cronjob.org:
# GET /api/cron/run
# Optional subset:
# GET /api/cron/run?jobs=send-scheduled,engagement
